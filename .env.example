# ============================================
# PROJECT CONFIGURATION
# ============================================
# Nombre del proyecto - usado en emails y notificaciones
PROJECT_NAME=my-frontend-project

# Entorno actual: development | staging | production
PROJECT_ENV=development

# ============================================
# API CONFIGURATION
# ============================================
# Endpoint GraphQL del backend
NEXT_PUBLIC_GRAPHQL_ENDPOINT=https://dev.topdev.mx/ksp/graphql

# URL base de la API REST (si aplica)
NEXT_PUBLIC_API_URL=https://api.example.com

# ============================================
# CLICKUP INTEGRATION (Refactored)
# ============================================
# API Key de ClickUp - Obtener en: ClickUp Settings > Apps > API Token
# Ejemplo: pk_123456_ABCDEFGHIJKLMNOPQRSTUVWXYZ
CLICKUP_API_KEY=pk_your_clickup_api_key_here

# ID del Workspace de ClickUp - Visible en la URL de ClickUp
# Ejemplo: 12345678
CLICKUP_WORKSPACE_ID=your_workspace_id

# ID del Folder existente en ClickUp (OPCIONAL)
# Si tienes un folder ya creado, especifica su ID aquí
# El script usará este folder en lugar de crear uno nuevo
# Ejemplo: 90123456789
CLICKUP_FOLDER_ID=your_folder_id

# ID de la Lista donde se crearán las tareas
# Se obtiene después de ejecutar el setup de ClickUp
CLICKUP_LIST_ID=your_list_id

# ClickUp Advanced Settings (Optional)
# Number of retry attempts for failed API requests (1-10)
CLICKUP_RETRY_ATTEMPTS=3

# Delay between retry attempts in milliseconds (100-60000)
CLICKUP_RETRY_DELAY=1000

# Request timeout in milliseconds (1000-300000)
CLICKUP_TIMEOUT=30000

# Log level for ClickUp operations (debug|info|warn|error)
CLICKUP_LOG_LEVEL=info

# Habilitar integración con ClickUp
NEXT_PUBLIC_CLICKUP_ENABLED=false

# ============================================
# AWS AMPLIFY (Parte 3)
# ============================================
# Credenciales AWS - Obtener en: AWS Console > IAM > Users
# Access Key ID
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE

# Secret Access Key (mantener seguro, nunca commitear)
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Región de AWS donde está Amplify
AWS_REGION=us-east-2

# ID de la aplicación en Amplify
# Se obtiene después de crear la app en Amplify
AMPLIFY_APP_ID=d1234567890abc

# Dominio de Amplify
# Ejemplo: my-app-dev.amplifyapp.com
AMPLIFY_DOMAIN=your-app.amplifyapp.com

# Habilitar deploy automático a Amplify
AMPLIFY_ENABLED=true

# ============================================
# SENDGRID EMAIL (Parte 4)
# ============================================
# API Key de SendGrid - Obtener en: SendGrid > Settings > API Keys
# Ejemplo: SG.1234567890abcdefghijklmnopqrstuvwxyz
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Email del remitente (debe estar verificado en SendGrid)
SENDGRID_FROM_EMAIL=noreply@your-domain.com

# Nombre del remitente
SENDGRID_FROM_NAME=My Project Team

# Lista de emails de developers (separados por comas)
# Recibirán notificaciones técnicas detalladas
DEV_EMAILS=dev1@example.com,dev2@example.com,dev3@example.com

# Lista de emails de clientes (separados por comas)
# Recibirán notificaciones user-friendly
CLIENT_EMAILS=client1@example.com,client2@example.com

# ============================================
# GITHUB CONFIGURATION (Parte 3)
# ============================================
# Token de GitHub - Obtener en: GitHub Settings > Developer settings > Personal access tokens
# Permisos necesarios: repo, workflow
# Ejemplo: ghp_1234567890abcdefghijklmnopqrstuvwxyz
GITHUB_TOKEN=ghp_your_github_token_here

# Owner del repositorio (organización o usuario)
GITHUB_REPO_OWNER=GRID-Company

# Nombre del repositorio
GITHUB_REPO_NAME=my-frontend-project

# ============================================
# AUTOMATION FEATURES
# ============================================
# Crear branches automáticamente desde issues
AUTO_CREATE_BRANCHES=true

# Actualizar ClickUp automáticamente en PRs
AUTO_UPDATE_CLICKUP=true

# Enviar notificaciones por email en releases
AUTO_SEND_NOTIFICATIONS=false

# Deploy automático al hacer merge a main
AUTO_DEPLOY_ON_MERGE=true
